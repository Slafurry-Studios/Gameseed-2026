  m_Script: {fileID: 11500000, guid: 733d0064b3af99f9e8e90499c246c2fa, type: 3}
  m_Name: Intro Bucket
  m_EditorClassIdentifier: 
  id: intro
  dialogs:
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Pandora
    dialog: Aaaand we've arrived!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Pandora
    dialog: Woo! Hello, viewers from across the entire multiverse!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Pandora
    dialog: Welcome back to the greatest, smartest, and most charismatic wizard in
      the universe!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Jormugandr
    dialog: You tripped over a rock three times while coming through the portal.
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Pandora
    dialog: That was part of the strategy!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Jormugandr
    dialog: You also opened the wrong portal and almost ended up in a chicken coop
      in Dimension 47.
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Pandora
    dialog: Advanced strategy!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Chat
    dialog: FIRST!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Chat
    dialog: "Wait\u2026 He's still alive?"
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Chat
    dialog: The snake is smarter than his grandma.
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Notification
    dialog: Donation $1
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Notification
    dialog: Can you destroy my granpa's house?
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Pandora
    dialog: Look, Sniki! We just got our very first donation in this world!
  - faceShotSprite: {fileID: 84243967, guid: 1911d66551321d6f0baeb880397beb20, type: 3}
    name: Jormugandr
    dialog: "Dear gods\u2026 why does every multiverse have people like this\u2026"
